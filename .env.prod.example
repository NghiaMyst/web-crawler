# Root .env.prod — used by docker-compose.prod.yml (variable substitution via ${VAR}).
# Copy to .env.prod on the Oracle server. NEVER commit the .env.prod file.

# Postgres credentials (also referenced by apps/api/.env.prod ConnectionStrings).
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# CORS — set this to the Vercel deployment URL after Plan 10-03 deploys the dashboard.
# Example: https://your-project.vercel.app  (no trailing slash; comma-separated for multiple).
CORS_ALLOWED_ORIGINS=https://CHANGE_ME.vercel.app

# Notification secrets — populate from Telegram / Discord dashboards.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Optional API keys.
RIOT_API_KEY=
