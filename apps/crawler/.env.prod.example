# Production crawler environment variables.
# Copy to apps/crawler/.env.prod on the Oracle server. NEVER commit the .env.prod file.
NODE_ENV=production
LOG_LEVEL=info
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://crawler:CHANGE_ME_STRONG_PASSWORD@postgres:5432/webcrawler
FOOTBALL_DATA_API_KEY=your_token_here
