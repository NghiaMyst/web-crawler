# Vercel production environment variables for the dashboard.
# Set these in: Vercel Dashboard → <project> → Settings → Environment Variables (Production scope).
# DO NOT copy this file into a real .env.production — Vercel reads from its UI, not this file.

# Public — baked into the JS bundle at build time. Browser-side fetch and SignalR connect target.
# MUST be https:// so SignalR upgrades to wss:// (browser mixed-content rules).
NEXT_PUBLIC_API_URL=https://<DUCKDNS_DOMAIN>

# Server-only — used by app/lib server-side fetchers (e.g., lib/api.server.ts).
# Same value as NEXT_PUBLIC_API_URL; kept separate so server code never reads the public-prefixed var.
API_URL=https://<DUCKDNS_DOMAIN>

# NODE_ENV is set automatically by Vercel to "production" for Production deployments.
