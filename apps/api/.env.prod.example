# Production API environment variables.
# Copy to apps/api/.env.prod on the Oracle server. NEVER commit the .env.prod file.
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=webcrawler;Username=crawler;Password=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=redis://redis:6379
# CORS_ALLOWED_ORIGINS is provided via docker-compose.prod.yml environment block (read from .env.prod or shell env).
# Example value (set in root .env.prod, not here): https://your-project.vercel.app
