{
  "id": null,
  "uid": "crawler-overview",
  "title": "Crawler Overview",
  "editable": true,
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "BullMQ Job Count by State",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "bullmq_job_count",
          "legendFormat": "{{queue}} - {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Crawl Duration Percentiles (p50 / p95)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(crawler_crawl_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 {{queue}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(crawler_crawl_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{queue}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Completed Jobs Rate (5m)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(bullmq_job_count{state=\"completed\"}[5m])",
          "legendFormat": "{{queue}} completed/s",
          "refId": "A"
        }
      ]
    }
  ]
}
